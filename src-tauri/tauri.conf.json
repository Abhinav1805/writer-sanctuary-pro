{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Writer Sanctuary Pro",
  "version": "0.1.0",
  "identifier": "com.abhinav.writersanctuarypro",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:8080/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Writer Sanctuary Pro",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
